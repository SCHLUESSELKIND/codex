{
  "$name": "BUILD ON PURPOSE",
  "$description": "Design-Tokens der Live-Show. Spiegelt src/styles/tokens.css. Bei Änderungen beide Dateien pflegen.",
  "color": {
    "bg": {
      "primary": "#060606",
      "elevated": "#0c0c0d",
      "surface": "#121214"
    },
    "border": {
      "subtle": "rgba(244,244,241,0.12)",
      "strong": "rgba(244,244,241,0.28)"
    },
    "text": {
      "primary": "#f4f4f1",
      "secondary": "#a7a7a0",
      "muted": "#62625c"
    },
    "signal": {
      "live": "#ff2b2b",
      "liveDim": "rgba(255,43,43,0.16)",
      "orange": "#f57b1f",
      "success": "#2fbf71",
      "warning": "#ffb020",
      "inactive": "#3a3a36"
    },
    "$rules": [
      "Rot steht ausschliesslich fuer LIVE, Aufnahme und aktuelle Aktion.",
      "Orange ist der ZehnX-Herkunftsakzent und erscheint nur als einzelner Punkt, Buchstabe oder Tick.",
      "Rot und Orange nie gleichzeitig grossflaechig."
    ]
  },
  "font": {
    "display": "Archivo Black",
    "ui": "Inter",
    "uiWeights": [500, 600, 700, 800, 900]
  },
  "type": {
    "display": { "size": 176, "leading": 0.92, "tracking": "-0.01em", "font": "display" },
    "episode": { "size": 96, "leading": 0.94, "tracking": "-0.01em", "font": "display" },
    "thumbnail": { "size": [78, 88, 104, 132], "leading": 0.94, "font": "display" },
    "segment": { "size": 64, "leading": 0.94, "font": "display" },
    "lowerThirdName": { "size": 42, "leading": 1.0, "font": "display" },
    "lowerThirdSub": { "size": 22, "leading": 1.4, "font": "ui", "weight": 600 },
    "body": { "size": 24, "leading": 1.4, "font": "ui", "weight": 500 },
    "meta": { "size": 18, "tracking": "0.14em", "font": "ui", "weight": 600 },
    "status": { "size": 16, "tracking": "0.22em", "font": "ui", "weight": 800 },
    "uiLabel": { "size": 13, "tracking": "0.14em", "font": "ui", "weight": 700 }
  },
  "space": { "1": 4, "2": 8, "3": 12, "4": 16, "6": 24, "8": 32, "12": 48, "16": 64, "24": 96, "32": 128 },
  "stage": {
    "broadcast": { "width": 1920, "height": 1080, "safeX": 96, "safeY": 54 },
    "thumbnail": { "width": 1280, "height": 720, "pad": 56, "portraitZoneX": 760 },
    "banner": { "width": 2560, "height": 1440, "safeWidth": 1546, "safeHeight": 423 },
    "social": {
      "square": { "width": 1080, "height": 1080 },
      "portrait": { "width": 1080, "height": 1350 },
      "story": { "width": 1080, "height": 1920 },
      "pad": 88
    }
  },
  "line": { "hair": 1, "strong": 2, "accent": 4 },
  "radius": { "broadcast": 0, "ui": 2 },
  "opacity": { "grid": 0.1, "ghost": 0.35 },
  "shadow": { "plate": "0 4px 32px rgba(0,0,0,0.55)" },
  "motion": {
    "micro": 150,
    "reveal": 300,
    "segment": 550,
    "ambientLoop": 24000,
    "easeSnap": "cubic-bezier(0.2, 0, 0, 1)",
    "easeScan": "cubic-bezier(0.65, 0, 0.35, 1)",
    "$rules": [
      "Puls ausschliesslich beim LIVE-Indikator.",
      "Kein Bounce, kein Spring, kein Overshoot.",
      "Das Design muss ohne Animation vollstaendig wirken."
    ]
  }
}
